{
  "id": "dream-police",
  "name": "Dream Police",
  "description": "Supervises dream memory consolidations. Uses an external verifier to fact-check promotions and re-runs the dream with targeted critiques before flagging anything that still fails.",
  "uiHints": {
    "enabled": {
      "label": "Enabled",
      "help": "Turn the dream-police supervisor on. Disabled by default."
    },
    "verifier.provider.baseUrl": {
      "label": "Verifier Base URL",
      "help": "OpenAI-compatible base URL for the verifier model (e.g. https://api.openai.com/v1)."
    },
    "verifier.provider.apiKeyEnv": {
      "label": "API Key Env Var",
      "help": "Name of the environment variable holding the verifier API key. The key itself never lives in config."
    },
    "verifier.provider.model": {
      "label": "Verifier Model",
      "help": "Model id to use for verification and correction."
    },
    "retry.maxRounds": {
      "label": "Max Correction Rounds",
      "help": "How many times dream-police will ask the dreamer to revise before flagging for manual review."
    },
    "sensitivity.onSensitive": {
      "label": "On Sensitive Content",
      "help": "What to do when a memory is tagged as private: skip verification, redact before sending, or flag in the audit file."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean" },
      "dryRun": { "type": "boolean" },
      "verifier": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "provider": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "baseUrl": { "type": "string" },
              "apiKeyEnv": { "type": "string" },
              "model": { "type": "string" },
              "timeoutMs": { "type": "number", "minimum": 1000 },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          },
          "corrector": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "baseUrl": { "type": "string" },
              "apiKeyEnv": { "type": "string" },
              "model": { "type": "string" },
              "timeoutMs": { "type": "number", "minimum": 1000 },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          },
          "priorContextLines": { "type": "integer", "minimum": 0, "maximum": 500 },
          "systemPromptOverride": { "type": "string", "minLength": 1, "maxLength": 10000 },
          "quorum": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "providers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "baseUrl": { "type": "string" },
                    "apiKeyEnv": { "type": "string" },
                    "model": { "type": "string" },
                    "timeoutMs": { "type": "number", "minimum": 1000 },
                    "headers": {
                      "type": "object",
                      "additionalProperties": { "type": "string" }
                    }
                  }
                }
              },
              "policy": {
                "type": "string",
                "enum": ["conservative", "majority", "unanimous"]
              }
            }
          }
        }
      },
      "retry": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "maxRounds": { "type": "integer", "minimum": 0, "maximum": 5 }
        }
      },
      "scope": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "minApplied": { "type": "integer", "minimum": 1 }
        }
      },
      "sensitivity": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "pathPatterns": {
            "type": "array",
            "items": { "type": "string" }
          },
          "onSensitive": {
            "type": "string",
            "enum": ["skip", "redact", "flag"]
          }
        }
      },
      "history": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "file": { "type": "string" },
          "logAccepted": { "type": "boolean" }
        }
      },
      "snapshots": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "dir": { "type": "string" },
          "keep": { "type": "integer", "minimum": 1, "maximum": 1000 }
        }
      },
      "circuitBreaker": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "threshold": { "type": "integer", "minimum": 1, "maximum": 100 }
        }
      },
      "events": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "file": { "type": "string" }
        }
      },
      "auditFile": { "type": "string" },
      "pauseFile": { "type": "string" },
      "pollIntervalMs": { "type": "number", "minimum": 250 }
    }
  }
}
